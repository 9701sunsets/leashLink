menu "leashLink"

config LEASHLINK_SENSOR_BRINGUP_ONLY
    bool "Sensor bring-up board only"
    default y
    help
        Enable this when only the light sensor, I2C heart sensor, and OLED are connected.
        It skips HX711, servo, motor, buzzer, GPS, ESP-NOW safety, and cloud telemetry tasks.

config LEASHLINK_WIFI_SEED_ON_BOOT
    bool "Seed WiFi credentials to NVS on boot"
    default n

config LEASHLINK_WIFI_SSID
    string "Phone hotspot SSID"
    default ""

config LEASHLINK_WIFI_PASSWORD
    string "Phone hotspot password"
    default ""

config LEASHLINK_MQTT_URI
    string "MQTT broker URI"
    default "mqtt://192.168.43.1:1883"

endmenu
