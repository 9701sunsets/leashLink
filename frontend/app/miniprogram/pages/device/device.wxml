<view class="page">
  <view class="section-title">我的设备</view>
  <view class="device-list">
    <device-card name="手柄端" model="{{handleId}} · ESP32-C3" online="{{status.online}}" battery="{{status.handle.battery_pct}}" meta="{{status.handle.gps.fix ? 'GPS 正常' : 'GPS 未定位'}}" />
    <device-card name="项圈端" model="{{collarId}} · ESP32-C5" online="{{status.online}}" battery="{{status.collar.battery_pct}}" meta="运动 {{status.collar.motion_state}} · RSSI {{status.collar.rssi_dbm}}dBm" />
  </view>
  <view class="section-title">快捷操作</view>
  <view class="ops card">
    <button class="primary-button" bindtap="findDog">启动寻狗</button>
    <button class="secondary-button" bindtap="rePair">重新配对</button>
    <button class="secondary-button" bindtap="openConfig">参数设置</button>
  </view>
  <view class="firmware card">
    <text>固件版本</text>
    <text>handle 0.1.0 · collar 0.1.0</text>
  </view>
</view>

