.map-page {
  min-height: 100vh;
  background: #f7fafc;
}

.map {
  width: 100%;
  height: 64vh;
}

.panel {
  margin: -24rpx 28rpx 0;
  padding: 28rpx;
  position: relative;
  z-index: 2;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.sub {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.radius {
  font-size: 44rpx;
  font-weight: 900;
  color: #36c76c;
}

