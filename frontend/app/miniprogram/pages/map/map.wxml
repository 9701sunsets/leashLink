<view class="map-page">
  <map
    class="map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="16"
    markers="{{markers}}"
    polyline="{{polyline}}"
    circles="{{circles}}"
    show-location
  />
  <view class="panel card">
    <view class="panel-head">
      <view>
        <text class="title">电子围栏</text>
        <text class="sub">当前位置为圆心，超出阈值触发提醒</text>
      </view>
      <text class="radius">{{radius}}m</text>
    </view>
    <slider min="30" max="300" step="10" value="{{radius}}" activeColor="#36C76C" bindchange="onRadiusChange" />
    <button class="primary-button" bindtap="saveFence">保存围栏</button>
  </view>
</view>

